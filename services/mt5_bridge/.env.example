TORUM_API_BASE_URL=http://127.0.0.1:8000
TORUM_TICKS_BATCH_ENDPOINT=/api/ticks/batch
TORUM_HEALTH_ENDPOINT=/api/health
TORUM_SYMBOLS_ENDPOINT=/api/symbols
TORUM_MT5_STATUS_ENDPOINT=/api/mt5/status
TORUM_HTTP_TIMEOUT_SECONDS=10
TORUM_HTTP_MAX_RETRIES=3

MT5_POLL_INTERVAL_MS=250
MT5_BATCH_MAX_SIZE=500
MT5_BATCH_FLUSH_INTERVAL_MS=1000
MT5_BUFFER_MAX_SIZE=50000
MT5_LOOKBACK_SECONDS_ON_START=10
MT5_COPY_TICKS_MAX_COUNT=10000
MT5_ENABLE_REAL_TRADING=false
MT5_ALLOWED_ACCOUNT_MODES=DEMO
MT5_PRICE_SOURCE=auto
MT5_MAGIC_NUMBER=260426
MT5_MARKET_DATA_ONLY=true
MT5_SYMBOLS=
MT5_FALLBACK_SYMBOL_MAPPINGS=XAUUSD:XAUUSD,XAUEUR:XAUEUR,XAUAUD:XAUAUD,XAUJPY:XAUJPY,DXY:DXY
MT5_BRIDGE_HOST=127.0.0.1
MT5_BRIDGE_PORT=9100
MT5_ALLOW_ORDER_EXECUTION=false
MT5_DEFAULT_DEVIATION_POINTS=20
MT5_ORDER_COMMENT_PREFIX=Torum

LOG_LEVEL=INFO
