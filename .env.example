# Torum local environment
# Copy this file to .env before running Docker Compose.

PROJECT_NAME=Torum
ENVIRONMENT=local
TAILSCALE_ENABLED=false
PUBLIC_HOST=localhost

# Docker Compose exposure. Use 0.0.0.0 for LAN/Tailscale access.
API_BIND_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL / TimescaleDB
POSTGRES_DB=torum
POSTGRES_USER=torum
POSTGRES_PASSWORD=change-postgres-password
DATABASE_URL=postgresql+psycopg://torum:change-postgres-password@timescaledb:5432/torum

# Redis
REDIS_URL=redis://redis:6379/0

# Backend HTTP security
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Initial users. Phase 1 supports only admin and trader roles.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@torum.dev
INITIAL_ADMIN_PASSWORD=change-admin-password
INITIAL_TRADER_USERNAME=trader
INITIAL_TRADER_EMAIL=trader@torum.dev
INITIAL_TRADER_PASSWORD=change-trader-password

# Trading safety defaults
TRADING_MODE=PAPER
MT5_BRIDGE_BASE_URL=http://host.docker.internal:9100
PRICE_STALE_AFTER_SECONDS=30
CANDLE_PRICE_SOURCE=BID
MOCK_MARKET_TICK_INTERVAL_SECONDS=1.0
LIVE_TRADING_ENABLED=false
DEFAULT_MAGIC_NUMBER=260426
DEFAULT_DEVIATION_POINTS=20

# News blocking defaults, implemented in later phases.
NEWS_BLOCK_ENABLED=false
NEWS_BLOCK_MINUTES_BEFORE=60
NEWS_BLOCK_MINUTES_AFTER=60

# PWA push notifications. Generate keys locally and do not commit real secrets.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@torum.dev
